{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "io.github.hei33enberg/strajkpolski-mcp",
  "description": "Verified Polish open data for AI agents: debt, budget, 460 MPs, votings, quotes, gov map, RAG.",
  "version": "0.3.2",
  "repository": {
    "url": "https://github.com/Hei33enberg/strajkpolski-mcp",
    "source": "github"
  },
  "websiteUrl": "https://strajkpolski.org",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@strajkpolski/mcp",
      "version": "0.3.2",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        {
          "name": "STRAJKPOLSKI_API_BASE",
          "description": "Override API base URL (self-host / testing)",
          "isRequired": false,
          "default": "https://strajkpolski.org/api"
        }
      ]
    }
  ]
}
